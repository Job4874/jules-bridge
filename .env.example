# Copy to .env and fill in (never commit .env)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_TO=operator@example.com

# Automated browser model loop used by /chat and reasoning model=fast|smart.
# Leave blank until the local browser-loop service is available.
BROWSER_MODEL_LOOP_URL=http://127.0.0.1:8765/model-loop

# SMTP (Gmail): use 465 SSL if port 587 STARTTLS times out on your network
SMTP_PORT=465
SMTP_USE_SSL=1

# Authentication token for God-Mode Bridge API
BRIDGE_TOKEN=change-me-local-bridge-token

# Mirror of BRIDGE_TOKEN for GCP VM worker relay (auto-filled by Ensure-JulesSecrets.ps1)
LOCAL_BRIDGE_TOKEN=

# Ngrok authtoken for remote access (stored in repo .env + ~/.jules mirror + ngrok CLI)
# Get yours: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Jules REST API (local bridge routes under /jules/api/*)
# First-time setup (CLI + optional REST): run scripts/setup-jules.ps1 from repo root
JULES_API_KEY=your-jules-rest-api-key
JULES_SOURCE=sources/github/owner/repo
JULES_USE_REST_API=0
JULES_API_BASE_URL=https://jules.googleapis.com/v1alpha
JULES_STARTING_BRANCH=master

# Host identity (school PC). Run scripts/Setup-SchoolIdentity.ps1 once.
JULES_IDENTITY=School-PC-RAM-64-GB
JULES_CONTEXT=[SCHOOL_COMPUTE]
