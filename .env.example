# Copy to .env and fill in (never commit .env)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_TO=operator@example.com

# Reasoning routes (model=fast|smart). Needs Generative Language API scope (not Agent Platform-only keys).
GEMINI_API_KEY=your-gemini-or-auth-key

# OpenRouter (preferred when set — uses free :free models for fast/smart aliases)
OPENROUTER_API_KEY=sk-or-v1-your-key
# Optional rotation list (comma-separated) when one key rate-limits
OPENROUTER_API_KEYS=sk-or-v1-key-one,sk-or-v1-key-two

# Chat routing: vm | vm_primary | local | auto (auto skips malformed local keys and prefers VM)
CHAT_ROUTE=vm

# Ngrok authtoken for start.py public tunnel (get from https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# Fallback public URL when ngrok is unavailable (e.g. LocalTunnel)
FALLBACK_TUNNEL_URL=https://your-subdomain.loca.lt

# SMTP (Gmail): use 465 SSL if port 587 STARTTLS times out on your network
SMTP_PORT=465
SMTP_USE_SSL=1

# Authentication token for God-Mode Bridge API
BRIDGE_TOKEN=JULES-SECURE-999

# Jules REST API (alpha) — preferred over CLI when set. Header: X-Goog-Api-Key
# Create at https://jules.google.com/settings#api
JULES_API_KEY=your-jules-rest-api-key
JULES_SOURCE=sources/github/Job4874/jules-bridge
JULES_USE_REST_API=1

# Optional GCP worker shown on the dashboard and used by the VM relay
GCE_WORKER_IP=34.132.193.73
GCE_WORKER_NAME=jules-offload-worker
GCE_WORKER_PROJECT=tibin-terminal-2026
GCE_WORKER_ZONE=us-central1-a
GCE_WORKER_USER=atibin7_gmail_com
