{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VRL",
  "scopeName": "source.vrl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#paths"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.vrl"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.vrl"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.vrl"
            }
          },
          "name": "string.quoted.double.vrl",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.vrl"
            },
            {
              "match": "\\$\\{[^}]*\\}",
              "name": "string.interpolated.vrl"
            }
          ]
        },
        {
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.vrl"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.vrl"
            }
          },
          "name": "string.quoted.single.vrl",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.vrl"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b-?(?:0x[0-9a-fA-F]+|\\d+(?:\\.\\d+)?)\\b",
          "name": "constant.numeric.vrl"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|else|for|in|return|abort|assert|nullish|match)\\b",
          "name": "keyword.control.vrl"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.vrl"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*!?)(?=\\s*\\()",
          "name": "entity.name.function.vrl"
        }
      ]
    },
    "paths": {
      "patterns": [
        {
          "match": "(^|[^a-zA-Z0-9_])((?:\\.[a-zA-Z_][a-zA-Z0-9_]*|\\[[^\\]]+\\])+)",
          "captures": {
            "2": {
              "name": "variable.other.property.vrl"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "==|!=|<=|>=|&&|\\|\\||[=+\\-*/%<>!]",
          "name": "keyword.operator.vrl"
        }
      ]
    }
  }
}
