{
  "If block": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "  ${0}",
      "}"
    ],
    "description": "Create an if block."
  },
  "If else block": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "  ${2}",
      "} else {",
      "  ${0}",
      "}"
    ],
    "description": "Create an if/else block."
  },
  "Assign field": {
    "prefix": "set",
    "body": ".${1:field} = ${0:value}",
    "description": "Assign a value to an event field."
  },
  "Abort": {
    "prefix": "abort",
    "body": "abort(\"${1:reason}\")",
    "description": "Abort processing with a reason."
  }
}
